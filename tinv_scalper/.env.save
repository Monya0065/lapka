# Run mode: REAL / DRY_RUN / PAPER
BOT_MODE=DRY_RUN

# Main loop
LOOP_INTERVAL_SEC=15
CONFIRM_SECONDS=15
RECONCILIATION_INTERVAL_SEC=60
UNIVERSE_RELOAD_SEC=900

# Entry thresholds
MIN_MOM_60M=0.006
MIN_MOM_5M=0.0015
MAX_SPREAD_PCT=0.15
EMERGENCY_SPREAD_PCT=0.35
MIN_VOLATILITY_THRESHOLD=0.0015
MAX_SLIPPAGE_PCT=0.25
MIN_EDGE=0.07

# Exit rules
TAKE_PROFIT_PCT=0.45
STOP_LOSS_PCT=0.35
TIME_STOP_SECONDS=1500

# Position sizing & leverage
RISK_PER_TRADE_PCT=0.005
MAX_LOTS_CAP=250
MAX_POSITION_RUB=250000
MAX_LEVERAGE=2.5

# Risk limits
DAILY_LOSS_LIMIT_RUB=-10000
MAX_TRADES_PER_DAY=20
COOLDOWN_AFTER_TRADE_SEC=60
COOLDOWN_AFTER_LOSSES_SEC=300
