# T-Invest credentials
# Option A: plain token in env
TINV_TOKEN=your_token_here
# Option B: leave TINV_TOKEN empty and load from macOS Keychain
KEYCHAIN_SERVICE=
KEYCHAIN_ACCOUNT=

TINV_ACCOUNT_ID=your_account_id_here

# Timezone and UI
TZ=Europe/Moscow
UI_HOST=127.0.0.1
UI_PORT=8000

# Run mode: REAL / DRY_RUN / PAPER
BOT_MODE=DRY_RUN
ALLOW_REAL=false
REQUIRE_PREFLIGHT_REAL=true
PREFLIGHT_REPORT_FILE=logs/preflight_real.json
PREFLIGHT_MAX_AGE_SEC=86400
REQUIRE_GO_LIVE_CHECK_REAL=true
GO_LIVE_REPORT_FILE=logs/go_live_check.json
GO_LIVE_MAX_AGE_SEC=21600
FLATTEN_ON_SHUTDOWN_REAL=false
DESKTOP_NOTIFY=true
UI_BASIC_AUTH_ENABLED=false
UI_BASIC_AUTH_USER=
UI_BASIC_AUTH_PASSWORD=

# Main loop
LOOP_INTERVAL_SEC=15
CONFIRM_SECONDS=15
RECONCILIATION_INTERVAL_SEC=60
UNIVERSE_RELOAD_SEC=900
MAX_INSTRUMENTS_PER_CYCLE=24
MAX_API_CALLS_PER_CYCLE=120
MAX_API_CALLS_PER_MINUTE=420
MAX_CANDLE_AGE_SEC=120
ADAPTIVE_SCAN_ENABLED=true
ADAPTIVE_SCAN_MIN_CAP=6
API_BUDGET_SOFT_RATIO=0.85
SCAN_RECOVERY_CYCLES=4
API_BUDGET_RECOVERY_CYCLES=4
API_BUDGET_RECOVER_RATIO=0.55

# Entry thresholds
MIN_MOM_60M=0.006
MIN_MOM_5M=0.0015
MAX_SPREAD_PCT=0.15
EMERGENCY_SPREAD_PCT=0.35
MIN_VOLATILITY_THRESHOLD=0.0015
MAX_SLIPPAGE_PCT=0.25
# expected edge after fee in percent points (0.07 = 0.07%)
MIN_EDGE=0.07
# MOMENTUM or COMPOSITE
STRATEGY_MODE=COMPOSITE
CANDIDATE_TOP_N=8
ORB_MINUTES=15
ORB_BREAKOUT_BUFFER_PCT=0.03
ORB_MIN_RANGE_PCT=0.08
ORB_WEIGHT=0.6
BB_PERIOD=20
BB_STDDEV=2.0
BB_MAX_DISTANCE_PCT=2.5
BB_REBOUND_WEIGHT=0.4
FORECAST_ENABLED=true
FORECAST_HORIZON_MIN=5
FORECAST_MIN_SAMPLES=16
FORECAST_WEIGHT=0.45
FORECAST_MIN_EDGE_PCT=0.03
FORECAST_MIN_CONFIDENCE=0.53
FORECAST_LR=0.35
FORECAST_L2=0.002
FORECAST_EPOCHS=8

# Exit rules
TAKE_PROFIT_PCT=0.45
TAKE_PROFIT_1_PCT=0.28
TAKE_PROFIT_1_FRACTION=0.50
TAKE_PROFIT_1_MIN_LOTS=1
STOP_LOSS_PCT=0.35
TIME_STOP_SECONDS=1500
TRAILING_ACTIVATION_PCT=0.20
TRAILING_STOP_PCT=0.25
BREAKEVEN_TRIGGER_PCT=0.20
BREAKEVEN_OFFSET_PCT=0.02

# Position sizing & leverage
RISK_PER_TRADE_PCT=0.005
MAX_LOTS_CAP=250
MAX_POSITION_RUB=250000
MAX_LEVERAGE=2.5

# Risk limits
DAILY_LOSS_LIMIT_RUB=-10000
MAX_DAILY_DRAWDOWN_RUB=-15000
MAX_LOSS_PER_SYMBOL_RUB=-4000
MAX_TRADES_PER_DAY=20
MAX_TRADES_PER_HOUR=6
MAX_DAILY_SLIPPAGE_PCT=3.5
COOLDOWN_AFTER_TRADE_SEC=60
COOLDOWN_AFTER_LOSSES_SEC=300
MAX_CONSECUTIVE_LOSSES=3
MAX_FAILED_ENTRIES_PER_SYMBOL=3
SYMBOL_BAN_SECONDS=3600
REENTRY_COOLDOWN_SEC=180
REENTRY_MIN_MOM5_DELTA=0.0007
MAX_NOTIONAL_PER_DAY_RUB=5000000
MAX_NOTIONAL_PER_HOUR_RUB=1500000
ORDER_FAILURE_CB_ENABLED=true
ORDER_FAILURE_CB_THRESHOLD=3
ORDER_FAILURE_CB_COOLDOWN_SEC=900
QUALITY_GUARD_ENABLED=true
QUALITY_GUARD_MIN_TRADES=8
QUALITY_GUARD_WINDOW_TRADES=60
QUALITY_GUARD_MAX_AVG_SLIPPAGE_PCT=0.35
QUALITY_GUARD_MIN_AVG_FILL_RATIO=0.82
QUALITY_GUARD_MAX_SLIPPAGE_STD_PCT=0.22
QUALITY_GUARD_MAX_SPREAD_SLIP_CORR=0.85
QUALITY_GUARD_SEVERE_MULT=1.6
QUALITY_GUARD_RISK_CUT=0.65
QUALITY_GUARD_RECOVERY_CYCLES=6

# Execution
ORDER_FILL_TIMEOUT_SEC=35
MAX_RETRY_ERRORS=5
MAX_API_LATENCY_MS=3000
LATENCY_RECOVERY_CYCLES=4
LATENCY_RECOVER_RATIO=0.7
ORDER_SLICES=3
LIMIT_ORDER_AGGR_BPS=4
LIQUIDITY_DEPTH_LEVELS=5
MIN_TOP_BOOK_QTY=120
MIN_TOP_BOOK_NOTIONAL_RUB=250000
MIN_BID_ASK_RATIO=0.85
MAX_BID_ASK_RATIO=4.0
BLUECHIP_SPREAD_MULT=1.25
STANDARD_SPREAD_MULT=1.00
THIN_SPREAD_MULT=0.75
BLUECHIP_SLIPPAGE_MULT=1.20
STANDARD_SLIPPAGE_MULT=1.00
THIN_SLIPPAGE_MULT=0.75
COMMISSION_BPS=5

# Volatility breaker
ABNORMAL_CANDLE_PCT=2.8
ABNORMAL_PAUSE_SEC=600

# MOEX trading window (local TZ)
MOEX_START=10:05
MOEX_END=18:40
NO_TRADE_MINUTES_AFTER_OPEN=3
NO_TRADE_MINUTES_BEFORE_CLOSE=5

# Files and logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
STATE_FILE=state.json
SQLITE_FILE=logs/bot.db
HEARTBEAT_FILE=logs/heartbeat.txt
RUNTIME_CONFIG_FILE=logs/runtime_config.json
BACKUP_ENABLED=true
BACKUP_INTERVAL_SEC=900
BACKUP_DIR=backups
BACKUP_KEEP=48
DISK_GUARD_MIN_FREE_MB=800
DISK_GUARD_RECOVER_RATIO=1.30
DISK_GUARD_CHECK_SEC=30
