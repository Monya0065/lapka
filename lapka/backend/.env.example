APP_NAME=Lapka API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+asyncpg://lapka:lapka@db:5432/lapka
SYNC_DATABASE_URL=postgresql://lapka:lapka@db:5432/lapka
# Optional SQLAlchemy pool tuning (async engine)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=1800

JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PHARMACY_PROVIDER=demo
PHARMACY_AVAILABILITY_RATE_LIMIT=40
PHARMACY_AVAILABILITY_WINDOW_SEC=60
PAYMENTS_PROVIDER=demo
LABS_PROVIDER=demo

# AI provider routing: noop | yandexgpt | groq | ollama | openai
LLM_PROVIDER=noop
LLM_FALLBACK_PROVIDER=noop
# YandexGPT (РФ): каталог Yandex Cloud → сервисный аккаунт → API-ключ; каталог = folder id
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=
# Опционально вместо API-ключа: краткоживший IAM (Bearer), см. документацию IAM
YANDEX_CLOUD_IAM_TOKEN=
YANDEXGPT_MODEL=yandexgpt-lite/latest
# Groq (free tier): https://console.groq.com/keys — OpenAI-compatible API
GROQ_API_KEY=
# Groq is not available from Russia, China, Iran, DPRK, Syria, Cuba (HTTP 403). Use ollama/openai or an allowed network.
GROQ_MODEL=llama-3.3-70b-versatile
# Local Ollama (no cloud key): install ollama, `ollama pull llama3.2`, `ollama serve`
# From Docker API container use host: OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# MVP lost-pet boost (Stripe Checkout)
APP_PUBLIC_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LOST_PET_BOOST_ID=
MVP_ADMIN_NOTIFY_EMAIL=
MVP_TELEGRAM_BOT_TOKEN=
MVP_TELEGRAM_CHAT_ID=
# Пилот: если задан, страница быстрого triage и оплата буста требуют этот код
MVP_INVITE_CODE=

# --- VPN MVP (таблицы только через Alembic revision 040_vpn_mvp; без миграций API вернёт VPN_SCHEMA_MISSING) ---
VPN_YOOKASSA_WEBHOOK_SECRET=
VPN_CLOUDPAYMENTS_WEBHOOK_SECRET=
VPN_TBANK_WEBHOOK_SECRET=
VPN_DEFAULT_DEVICE_LIMIT=5
# Выдача wireguard.conf (prod)
VPN_WG_SERVER_PUBLIC_KEY=
VPN_WG_ENDPOINT=
VPN_WG_ALLOWED_IPS=0.0.0.0/0, ::/0
VPN_WG_DNS=1.1.1.1
# Агент ноды: Bearer + опционально URL для POST при выдаче ключей клиенту
VPN_NODE_AGENT_BEARER_TOKEN=
VPN_NODE_AGENT_NOTIFY_URL=
# Опционально: CIDR через запятую (например 10.8.0.0/24,172.16.0.0/12). Пусто = только Bearer, без проверки IP.
VPN_NODE_AGENT_ALLOWED_CIDRS=
# Если TCP-клиент в этих CIDR (ingress), для allowlist берётся первый (левый) hop из X-Forwarded-For. Пусто = только request.client.host.
# Рассчитано на один доверенный reverse-proxy: при цепочке из нескольких прокси клиент может подставить левый адрес — не ставьте сюда публичные сети без контроля ingress.
VPN_NODE_AGENT_TRUSTED_PROXY_CIDRS=
