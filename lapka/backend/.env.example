APP_NAME=Lapka API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+asyncpg://lapka:lapka@db:5432/lapka
SYNC_DATABASE_URL=postgresql://lapka:lapka@db:5432/lapka

JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PHARMACY_PROVIDER=demo
PHARMACY_AVAILABILITY_RATE_LIMIT=40
PHARMACY_AVAILABILITY_WINDOW_SEC=60
PAYMENTS_PROVIDER=demo
LABS_PROVIDER=demo

# AI provider routing
LLM_PROVIDER=noop
LLM_FALLBACK_PROVIDER=noop
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

