  "responsive": {
    "desktop": 1200,
    "tablet": 960,
    "mobile": 640,
    "rules": [
      "Stack cards to single column below 960px",
      "Reduce heading size by 20% on mobile",
      "Expand button width to 100% on mobile"
    ]
  }
}
